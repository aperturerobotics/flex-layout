{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "declaration": true,
    "emitDeclarationOnly": true
  },
  "include": ["./src/**/*"],
  "exclude": [
    "dist",
    "typedoc",
    "./src/test/**",
    "./src/**/*.test.ts",
    "./src/**/*.test.tsx",
    "./src/**/*.e2e.test.ts",
    "./src/**/*.e2e.test.tsx"
  ]
}
